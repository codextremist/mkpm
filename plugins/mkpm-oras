# See oras https://oras.land/ and https://www.kenmuse.com/blog/universal-packages-on-github-with-oras/
_mkpm_plugin_oras_artifact_type := application/vnd.mkpm.config+gzip
_mkpm_plugin_oras_version := 1.3.2
_mkpm_plugin_oras_installed := $(if $(shell command -v oras),t)

define _mkpm_plugin_oras_registry_host
$(word 1,$(subst /, ,$(call mkpm_registry)))
endef

define _mkpm_plugin_oras_login
oras login $(call _mkpm_plugin_oras_registry_host) -u "$(call mkpm_registry_user)" --password "$(call mkpm_registry_token)"
endef

define _mkpm_plugin_oras_login_interactive
$(quiet)echo "When using GitHub (ghcr.io), use your PAT (Personal Access Token) as your password. Press enter to quit"
$(quiet)oras login $(call _mkpm_plugin_oras_registry_host) -u "$(call mkpm_registry_user)"
endef

define _mkpm_plugin_oras_logout
oras logout $(call _mkpm_plugin_oras_registry_host)
endef

define _mkpm_plugin_oras_install
$(quiet)echo "Installing oras $(or $(1),$(_mkpm_plugin_oras_version)) for $(_mkpm_os)/$(_mkpm_arch)..."
$(quiet)ver="$(or $(1),$(_mkpm_plugin_oras_version))"; tmp="$$(mktemp -d)"; \
curl -fsSL "https://github.com/oras-project/oras/releases/download/v$$ver/oras_$${ver}_$(_mkpm_os)_$(_mkpm_arch).tar.gz" -o "$$tmp/oras.tar.gz" && \
tar -zxf "$$tmp/oras.tar.gz" -C "$$tmp" && \
sudo mv "$$tmp/oras" /usr/local/bin/ && \
rm -rf "$$tmp"
endef

# Function override
define mkpm_publish
$(quiet)Publishing package $(2):$(3)...
$(if $(_mkpm_plugin_oras_installed),,$(call _mkpm_plugin_oras_install))
$(if $(CI),$(call _mkpm_plugin_oras_login))
oras push $(call mkpm_registry)/$(2):$(3) --disable-path-validation --artifact-type $(call _mkpm_plugin_oras_artifact_type) $(1)
endef

# Function override
define mkpm_download
$(quiet)echo "Downloading package $(call _mkpm_dep_name,$(1))$(if $(call _mkpm_dep_version,$(1)),:$(call _mkpm_dep_version,$(1)))..." && \
oras pull $(call mkpm_registry)/$(call _mkpm_dep_name,$(1)):$(or $(call _mkpm_dep_version,$(1)),latest) 2>/tmp/mkpm-oras-err.$$$$ || { \
  echo "mkpm: failed to fetch '$(call _mkpm_dep_name,$(1))' from $(call mkpm_registry) (package missing or registry unreachable)" >&2; \
  sed 's/^/  | /' /tmp/mkpm-oras-err.$$$$ >&2; \
  rm -f /tmp/mkpm-oras-err.$$$$; \
  exit 1; \
} && rm -f /tmp/mkpm-oras-err.$$$$
endef

ifeq ($(_mkpm_target_ns),)
$(call mkpm_help,mkpm-plugin-oras-install,Install ORAS)
.PHONY: mkpm-plugin-oras-install
mkpm-plugin-oras-install:
	$(quiet)$(if $(_mkpm_plugin_oras_installed),printf "\033]0;93moras already installed\033[0m\n",$(call _mkpm_plugin_oras_install))

$(call mkpm_help,mkpm-plugin-oras-login,Log in to registry)
.PHONY: mkpm-plugin-oras-login
mkpm-plugin-oras-login:
	$(call _mkpm_plugin_oras_login_interactive)

$(call mkpm_help,mkpm-plugin-oras-logout,Log out from registry)
.PHONY: mkpm-plugin-oras-logout
mkpm-plugin-oras-logout:
	$(call _mkpm_plugin_oras_logout)
endif